{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Render README.rst",
            "type": "debugpy",
            "request": "launch",
            "module": "readme_renderer",
            "args": ["${workspaceFolder}/README.rst"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug current pytest file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
